.diary-container {
  padding: 16px 16px 40px 16px;
  background-color: var(--theme-bg, #F7F4EF);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 20px;
  padding-left: 4px;
}

.title {
  font-size: 24px;
  font-weight: 800;
  color: var(--theme-text-main, #333333);
  letter-spacing: 0.5px;
  display: block;
}

.subtitle {
  font-size: 12px;
  color: var(--theme-text-sub, #777777);
  margin-top: 6px;
  display: block;
  font-weight: 300;
}

/* 卡片基础设计 */
.checkin-card, .comparison-card, .weekly-report-card {
  padding: 20px;
  margin-bottom: 18px;
  box-sizing: border-box;
}

.card-header {
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--theme-text-main, #333333);
  display: block;
}

.card-tip {
  font-size: 11px;
  color: var(--theme-text-sub, #777777);
  margin-top: 2px;
  display: block;
}

/* 输入表单行 */
.input-row {
  margin-bottom: 20px;
}

.slider-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.label {
  font-size: 13px;
  font-weight: 600;
  color: var(--theme-text-main, #333333);
}

.slider-value {
  font-size: 13px;
  font-weight: 700;
  color: var(--theme-primary, #E8A08A);
}

.slider-hint {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  color: var(--theme-text-sub, #777777);
  padding: 0 10px;
  margin-top: -4px;
}

/* 精美生活诱因胶囊多选框 */
.badge-group {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8px;
}

.badge-item {
  font-size: 12px;
  padding: 6px 14px;
  background-color: rgba(255, 255, 255, 0.6);
  color: var(--theme-text-sub, #777777);
  border-radius: 20px;
  margin-right: 10px;
  margin-bottom: 10px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  transition: all 0.25s ease;
  display: inline-block;
  text-align: center;
}

.badge-item.active {
  background-color: var(--theme-primary, #E8A08A);
  color: #FFFFFF;
  border-color: var(--theme-primary, #E8A08A);
  box-shadow: 0 4px 10px rgba(232, 160, 138, 0.3);
  transform: translateY(-1px);
}

/* 照片上传区域 */
.photo-upload-area {
  width: 100%;
  height: 160px;
  margin-top: 8px;
  border: 1px dashed rgba(198, 164, 154, 0.4);
  border-radius: 12px;
  background-color: rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.photo-upload-area:active {
  background-color: rgba(255, 255, 255, 0.6);
}

.preview-img {
  width: 100%;
  height: 100%;
}

.upload-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 32px;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.overlay-text {
  font-size: 11px;
  color: #FFFFFF;
  font-weight: 500;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px;
}

.upload-icon {
  font-size: 28px;
  color: var(--theme-secondary, #C6A49A);
  line-height: 1;
  margin-bottom: 6px;
}

.upload-text {
  font-size: 13px;
  font-weight: 600;
  color: var(--theme-text-main, #333333);
}

.upload-sub {
  font-size: 10px;
  color: var(--theme-text-sub, #777777);
  margin-top: 4px;
  text-align: center;
}

/* 保存按钮 */
.save-diary-btn {
  width: 100% !important;
  background: linear-gradient(135deg, var(--theme-primary, #E8A08A) 0%, var(--theme-secondary, #C6A49A) 100%);
  color: #FFFFFF;
  font-size: 15px;
  font-weight: bold;
  border-radius: 24px;
  padding: 10px 0;
  margin-top: 8px;
  box-shadow: 0 4px 12px rgba(232, 160, 138, 0.25);
  border: none;
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.985);
}

/* Canvas 对比区域 */
.canvas-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10px;
}

.compare-canvas {
  width: 300px;
  height: 200px;
  background-color: #EFEFEF;
  border-radius: 12px;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.05);
}

.slider-tip {
  font-size: 11px;
  color: var(--theme-text-sub, #777777);
  margin-top: 12px;
  font-weight: 500;
}

/* AI 周报卡片 */
.weekly-report-card {
  position: relative;
  overflow: hidden;
}

/* 未解锁锁状态 */
.lock-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 8px;
  text-align: center;
}

.lock-icon {
  margin-bottom: 12px;
}

.lock-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--theme-text-main, #333333);
}

.lock-desc {
  font-size: 12px;
  color: var(--theme-text-sub, #777777);
  margin-top: 8px;
  line-height: 1.6;
}

.progress-section {
  width: 100%;
  margin-top: 18px;
}

.progress-text-row {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--theme-text-sub, #777777);
  margin-bottom: 6px;
  font-weight: 500;
}

.progress-val {
  font-weight: 700;
  color: var(--theme-secondary, #C6A49A);
}

.progress-bg {
  height: 8px;
  background-color: rgba(0, 0, 0, 0.04);
  border-radius: 4px;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--theme-secondary, #C6A49A) 0%, var(--theme-primary, #E8A08A) 100%);
  border-radius: 4px;
  transition: width 0.4s ease;
}

/* 待解锁解锁大按钮 */
.unlock-prompt-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 8px;
  text-align: center;
}

.congrats-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--theme-success, #9AADA2);
}

.unlock-btn-group {
  width: 100%;
  margin-top: 20px;
}

.ad-unlock-btn {
  width: 100% !important;
  background-color: var(--theme-success, #9AADA2);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: bold;
  border-radius: 20px;
  padding: 10px 0;
  margin-bottom: 12px;
  box-shadow: 0 4px 10px rgba(154, 173, 162, 0.2);
  border: none;
}

.vip-unlock-btn {
  width: 100% !important;
  background-color: transparent;
  color: var(--theme-secondary, #C6A49A);
  font-size: 13px;
  font-weight: bold;
  border-radius: 20px;
  padding: 9px 0;
  border: 1px solid var(--theme-secondary, #C6A49A);
}

/* 已解锁：周报内容 */
.report-content-container {
  margin-top: 4px;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px dashed rgba(0, 0, 0, 0.05);
}

.report-tag {
  font-size: 11px;
  background-color: rgba(232, 160, 138, 0.15);
  color: var(--theme-primary, #E8A08A);
  padding: 3px 8px;
  border-radius: 4px;
  font-weight: 700;
}

.report-date {
  font-size: 11px;
  color: var(--theme-text-sub, #777777);
}

/* 周报版块 */
.report-section {
  padding: 12px 14px;
  border-radius: 10px;
  margin-bottom: 14px;
  border-left: 4px solid transparent;
}

.report-section.pink {
  background-color: rgba(232, 160, 138, 0.06);
  border-left-color: var(--theme-primary, #E8A08A);
}

.report-section.yellow {
  background-color: rgba(241, 196, 15, 0.06);
  border-left-color: #F1C40F;
}

.report-section.blue {
  background-color: rgba(52, 152, 219, 0.06);
  border-left-color: #3498DB;
}

.report-section.green {
  background-color: rgba(154, 173, 162, 0.06);
  border-left-color: var(--theme-success, #9AADA2);
}

.report-section.heart {
  background-color: rgba(198, 164, 154, 0.06);
  border-left-color: var(--theme-secondary, #C6A49A);
}

.section-badge {
  font-size: 12px;
  font-weight: 700;
  color: var(--theme-text-main, #333333);
  margin-bottom: 6px;
}

.report-text {
  font-size: 12.5px;
  line-height: 1.6;
  color: var(--theme-text-main, #333333);
  display: block;
  text-align: justify;
}

.bold-summary {
  font-weight: 600;
}

.plan-text {
  white-space: pre-wrap;
  font-family: inherit;
}

.quote-text {
  font-style: italic;
  color: var(--theme-secondary, #C6A49A);
  font-weight: 600;
}

.re-analyze-btn {
  width: 100% !important;
  background-color: rgba(198, 164, 154, 0.12);
  color: var(--theme-secondary, #C6A49A);
  font-size: 13px;
  font-weight: bold;
  border-radius: 20px;
  padding: 8px 0;
  margin-top: 10px;
  border: none;
}

/* 广告弹窗 */
.ad-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
}

.ad-content {
  width: 82%;
  padding: 24px;
  display: flex;
  flex-direction: column;
  border-radius: 16px;
  box-sizing: border-box;
}

.ad-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  padding-bottom: 8px;
}

.ad-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--theme-text-main, #333333);
}

.ad-timer {
  font-size: 12px;
  background-color: var(--theme-warning, #D98880);
  color: #FFFFFF;
  padding: 2px 8px;
  border-radius: 12px;
  font-weight: 700;
}

.ad-body {
  margin-bottom: 20px;
}

.ad-mock-img {
  width: 100%;
  height: 140px;
  border-radius: 8px;
  margin-bottom: 12px;
}

.ad-mock-text {
  font-size: 12.5px;
  color: var(--theme-text-main, #333333);
  line-height: 1.5;
  display: block;
}

.ad-skip-btn {
  background: linear-gradient(135deg, var(--theme-primary, #E8A08A) 0%, var(--theme-secondary, #C6A49A) 100%);
  color: #FFFFFF;
  font-size: 13.5px;
  font-weight: bold;
  border-radius: 20px;
  padding: 9px 0;
  border: none;
}

.ad-skip-btn[disabled] {
  background: #EFEFEF !important;
  color: var(--theme-text-sub, #777777) !important;
}

/* 动效 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes zoomIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.animate-fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.animate-slide-up {
  animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-zoom-in {
  animation: zoomIn 0.3s ease forwards;
}
