.add-container {
  padding: 20px 16px;
  background-color: var(--theme-bg);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 20px;
}

.title {
  font-size: 22px;
  font-weight: 800;
  color: var(--theme-text-main);
  letter-spacing: 0.5px;
}

.subtitle {
  font-size: 12px;
  color: var(--theme-text-sub);
  margin-top: 4px;
  display: block;
}

.ocr-card {
  padding: 18px;
  margin-bottom: 20px;
  background: linear-gradient(135deg, rgba(232, 160, 138, 0.08), rgba(255, 255, 255, 0.85));
  border: 1px solid rgba(232, 160, 138, 0.2);
}

.ocr-header {
  margin-bottom: 14px;
}

.ocr-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--theme-primary);
  display: block;
}

.ocr-desc {
  font-size: 11px;
  color: var(--theme-text-sub);
  line-height: 1.4;
  margin-top: 4px;
  display: block;
}

.ocr-btn {
  background: linear-gradient(135deg, var(--theme-success), #86998E);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  padding: 10px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(154, 173, 162, 0.3);
  border: none;
  width: 100%;
}

.ocr-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  margin-right: 8px;
  font-size: 16px;
}

.form-card {
  padding: 20px 16px;
}

.form-item {
  margin-bottom: 22px;
}

.label {
  font-size: 13px;
  font-weight: 700;
  color: var(--theme-text-main);
  margin-bottom: 8px;
  display: block;
}

.required {
  color: var(--theme-warning);
}

.name-input {
  background-color: rgba(0, 0, 0, 0.03);
  padding: 12px 14px;
  border-radius: 10px;
  font-size: 14px;
  color: var(--theme-text-main);
  border: 1px solid transparent;
  transition: all 0.3s;
}

.name-input:focus {
  border-color: rgba(232, 160, 138, 0.4);
  background-color: rgba(255, 255, 255, 0.6);
}

.placeholder-style {
  color: #BBB;
  font-size: 13px;
}

.capsule-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.capsule-tag {
  font-size: 12px;
  color: var(--theme-secondary);
  background-color: rgba(198, 164, 154, 0.12);
  padding: 6px 14px;
  border-radius: 16px;
  font-weight: 600;
  transition: all 0.2s ease;
}

.capsule-tag.active {
  color: #FFFFFF;
  background-color: var(--theme-primary);
  box-shadow: 0 3px 8px rgba(232, 160, 138, 0.25);
}

.picker-val {
  background-color: rgba(0, 0, 0, 0.03);
  padding: 12px 14px;
  border-radius: 10px;
  font-size: 14px;
  color: var(--theme-text-main);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 10px;
  color: var(--theme-text-sub);
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.pao-value-text {
  font-size: 13px;
  font-weight: 700;
  color: var(--theme-primary);
}

.pao-tips {
  font-size: 10px;
  color: var(--theme-text-sub);
  margin-top: 6px;
  line-height: 1.4;
}

.submit-btn {
  background: linear-gradient(135deg, var(--theme-primary), #E38E75);
  color: #FFFFFF;
  font-size: 15px;
  font-weight: 700;
  padding: 12px;
  border-radius: 24px;
  box-shadow: 0 4px 12px rgba(232, 160, 138, 0.3);
  margin-top: 30px;
  width: 100%;
}

.submit-btn:active {
  transform: scale(0.98);
}
