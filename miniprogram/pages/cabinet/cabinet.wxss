.cabinet-container {
  padding: 20px 16px;
  background-color: var(--theme-bg);
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.cabinet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.cabinet-title {
  font-size: 24px;
  font-weight: 800;
  color: var(--theme-text-main);
  letter-spacing: 0.5px;
}

.cabinet-subtitle {
  font-size: 12px;
  color: var(--theme-text-sub);
  margin-top: 4px;
}

.add-btn {
  background: linear-gradient(135deg, var(--theme-primary), #E38E75);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  padding: 8px 18px;
  border-radius: 20px;
  box-shadow: 0 4px 10px rgba(232, 160, 138, 0.3);
  margin: 0;
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2px 6px rgba(232, 160, 138, 0.2);
}

.shelf-scroll {
  flex: 1;
}

.shelf-section {
  margin-bottom: 28px;
  animation: fadeIn 0.6s ease-out both;
}

.shelf-title-bar {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}

.shelf-title {
  display: flex;
  align-items: center;
  font-size: 16px;
  font-weight: 700;
  color: var(--theme-secondary);
}

.shelf-icon {
  margin-right: 8px;
  font-size: 18px;
}

.shelf-name {
  color: var(--theme-text-main);
}

.shelf-count {
  font-size: 13px;
  color: var(--theme-text-sub);
  margin-left: 6px;
  font-weight: 500;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 14px;
}

.product-card {
  position: relative;
  padding: 16px 14px 12px 14px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 120px;
  box-sizing: border-box;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  overflow: hidden;
}

.product-card:active {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.05);
}

.product-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.p-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--theme-text-main);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 6px;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  max-height: 36px;
  overflow: hidden;
}

.ingredient-tag {
  font-size: 9px;
  color: var(--theme-secondary);
  background-color: rgba(198, 164, 154, 0.12);
  padding: 2px 6px;
  border-radius: 8px;
  font-weight: 600;
}

.pao-container {
  margin-top: auto;
}

.pao-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 10px;
  color: var(--theme-text-sub);
  margin-bottom: 5px;
  font-weight: 500;
}

.pao-text {
  font-weight: 600;
}

.pao-pao {
  background: rgba(0, 0, 0, 0.04);
  padding: 1px 4px;
  border-radius: 4px;
  font-size: 9px;
}

.pao-progress-bg {
  height: 6px;
  background-color: #EAE5DC;
  border-radius: 3px;
  overflow: hidden;
}

.pao-progress-bar {
  height: 100%;
  border-radius: 3px;
  transition: width 0.6s cubic-bezier(0.1, 0.8, 0.1, 1);
}

.pao-progress-bar.safe {
  background: linear-gradient(90deg, #9AADA2, #b2c4ba);
}

.pao-progress-bar.warning {
  background: linear-gradient(90deg, #E67E22, #F1C40F);
}

.pao-progress-bar.danger {
  background: linear-gradient(90deg, #D98880, #E74C3C);
}

.edit-btn {
  position: absolute;
  top: 4px;
  right: 28px;
  font-size: 12px;
  color: var(--theme-text-sub);
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
  border-radius: 50%;
  transition: all 0.2s ease;
  z-index: 10;
}

.edit-btn:active {
  opacity: 1;
  background-color: rgba(232, 160, 138, 0.15);
  color: var(--theme-primary);
}

.delete-btn {
  position: absolute;
  top: 4px;
  right: 6px;
  font-size: 16px;
  color: var(--theme-text-sub);
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
  border-radius: 50%;
  transition: all 0.2s ease;
  z-index: 10;
}

.delete-btn:active {
  opacity: 1;
  background-color: rgba(217, 136, 128, 0.15);
  color: var(--theme-warning);
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon-wrap {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.8;
}

.empty-text {
  font-size: 15px;
  color: var(--theme-text-sub);
  margin-bottom: 24px;
}

.empty-btn {
  background-color: var(--theme-primary);
  color: #FFFFFF;
  font-size: 15px;
  font-weight: 600;
  padding: 10px 24px;
  border-radius: 22px;
  box-shadow: 0 4px 12px rgba(232, 160, 138, 0.3);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
