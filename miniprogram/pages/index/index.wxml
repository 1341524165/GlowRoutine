<disclaimer id="disclaimer-modal" bind:agreed="onDisclaimerAgreed" />

<view class="container">
  <!-- 头部欢迎区 -->
  <view class="header-section animate-fade-in">
    <view class="header-left">
      <text class="date-text">{{todayDate}}</text>
      <text class="greeting-text">嗨，你的今日护肤方案</text>
    </view>
    <view class="skin-profile-badge" bindtap="goToQuestionnaire">
      <text class="profile-type">{{skinTypeChinese}}</text>
      <text class="profile-sensitivity">{{sensitivityChinese}}</text>
    </view>
  </view>

  <!-- 实时肤况与警报调节卡片 -->
  <view class="alert-control-card glass-card animate-slide-up">
    <view class="alert-card-header">
      <text class="alert-title">🚨 实时肤况异常（泛红警报）</text>
      <switch checked="{{isRedAlert}}" color="var(--theme-warning)" bindchange="onRedAlertToggle" />
    </view>
    <view class="alert-msg-box {{isRedAlert ? 'danger' : 'safe'}}">
      <text class="alert-msg-text">{{alertMessage}}</text>
    </view>
  </view>

  <!-- 早晚日程选项卡 -->
  <view class="tab-header animate-slide-up" style="animation-delay: 0.05s;">
    <view class="tab-btn {{activeTab === 'morning' ? 'active' : ''}}" bindtap="switchTab" data-tab="morning">
      <text class="tab-icon">☀️</text>
      <text class="tab-label">晨间日程</text>
    </view>
    <view class="tab-btn {{activeTab === 'evening' ? 'active' : ''}}" bindtap="switchTab" data-tab="evening">
      <text class="tab-icon">🌙</text>
      <text class="tab-label">夜间日程</text>
    </view>
  </view>

  <!-- 日程步骤列表 -->
  <scroll-view class="steps-scroll animate-slide-up" style="animation-delay: 0.1s;" scroll-y>
    <view class="steps-container">
      <block wx:if="{{currentSteps && currentSteps.length > 0}}">
        <view class="step-card glass-card {{item.completed ? 'completed' : ''}} {{item.disabled ? 'disabled-step' : ''}}" 
              wx:for="{{currentSteps}}" 
              wx:key="index"
              bindtap="toggleStepCompletion"
              data-index="{{index}}">
          
          <view class="checkbox-container">
            <view class="custom-checkbox {{item.completed ? 'checked' : ''}}"></view>
          </view>

          <view class="step-content">
            <view class="step-badge-row">
              <text class="step-badge">步骤 {{index + 1}}</text>
              <text class="step-name">{{item.step}}</text>
            </view>
            <text class="step-requirement">{{item.requirement}}</text>
            <text class="step-desc">{{item.desc}}</text>

            <!-- 绑定柜子已开封单品 -->
            <block wx:if="{{item.mappedProduct}}">
              <view class="product-badge animate-fade-in">
                <text class="badge-icon">🎒</text>
                <text class="product-info">已适配柜内：{{item.mappedProduct.product_name}}</text>
              </view>
            </block>
            <block wx:else>
              <view class="product-badge empty animate-fade-in" catchtap="goToCabinet">
                <text class="badge-icon">💡</text>
                <text class="product-info">柜子暂无此产品，去录入 ➔</text>
              </view>
            </block>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="empty-state">
          <text class="empty-text">方案加载中，请稍候...</text>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 底部悬浮打卡区 -->
  <view class="footer-action animate-slide-up" style="animation-delay: 0.15s;">
    <button class="checkin-btn" bindtap="onCheckIn">完成今日护肤并打卡</button>
  </view>
</view>

<!-- 遮罩与半屏打卡抽屉 -->
<view class="drawer-mask {{showDrawer ? 'show' : ''}}" bindtap="closeDrawer"></view>
<view class="checkin-drawer {{showDrawer ? 'show' : ''}} {{isDetailed ? 'detailed' : ''}}">
  <view class="drawer-header">
    <text class="drawer-title">📋 今日日程打卡</text>
    <text class="drawer-close" bindtap="closeDrawer">✕</text>
  </view>
  
  <view class="drawer-body">
    <view class="steps-preview">
      <text class="label">已完成步骤：</text>
      <text class="val">{{completedStepsText}}</text>
    </view>

    <block wx:if="{{!isDetailed}}">
      <button class="minimal-btn" bindtap="saveMinimalCheckIn" hover-class="btn-hover">一键极简打卡 🎉</button>
      <view class="expand-action" bindtap="toggleDetailed">
        <text class="expand-text">✍️ 记录今日自拍与肤况细节日记</text>
      </view>
    </block>

    <block wx:else>
      <scroll-view scroll-y class="detailed-scroll">
        <!-- 油腻感滑块 -->
        <view class="slider-row">
          <view class="slider-labels">
            <text class="label">今日油腻感</text>
            <text class="val">{{oiliness}} 星</text>
          </view>
          <slider min="1" max="5" value="{{oiliness}}" bindchange="onOilChange" activeColor="#E8A08A" block-size="20"/>
        </view>
        
        <!-- 状态排查 -->
        <view class="checkbox-row">
          <text class="label">肤况排查 (多选)</text>
          <checkbox-group bindchange="onStatusChange" class="badge-group">
            <label class="badge-item {{item.checked ? 'active' : ''}}" wx:for="{{statusOptions}}" wx:key="value">
              <checkbox value="{{item.value}}" checked="{{item.checked}}" hidden/>
              <text>{{item.name}}</text>
            </label>
          </checkbox-group>
        </view>

        <!-- 诱因排查 -->
        <view class="checkbox-row">
          <text class="label">生活诱因排查 (多选)</text>
          <checkbox-group bindchange="onTriggersChange" class="badge-group">
            <label class="badge-item {{item.checked ? 'active' : ''}}" wx:for="{{triggerOptions}}" wx:key="value">
              <checkbox value="{{item.value}}" checked="{{item.checked}}" hidden/>
              <text>{{item.name}}</text>
            </label>
          </checkbox-group>
        </view>

        <!-- 拍照 -->
        <view class="photo-row">
          <text class="label">今日素颜自拍 (双图对比素材)</text>
          <view class="drawer-photo-box" bindtap="onChooseImage">
            <block wx:if="{{photoPath}}">
              <image src="{{photoPath}}" mode="aspectFill" class="drawer-photo-preview"/>
            </block>
            <block wx:else>
              <view class="drawer-photo-placeholder">＋ 拍摄/选择素颜自拍</view>
            </block>
          </view>
        </view>
      </scroll-view>
      
      <button class="detailed-btn" bindtap="saveDetailedCheckIn" hover-class="btn-hover">保存今日详细日记 💾</button>
      <view class="collapse-action" bindtap="toggleDetailed">
        <text class="expand-text">返回极简打卡模式</text>
      </view>
    </block>
  </view>
</view>

